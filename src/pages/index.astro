<script is:inline src="https://cdn.tailwindcss.com"></script>
<!DOCTYPE html>
<html lang="hi">
<head>
    <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>UPITI Employees Association</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-gray-50 text-gray-800 font-sans flex flex-col min-h-screen">

    <header class="bg-white shadow-md border-b-4 border-blue-700">
        <div class="container mx-auto px-4 py-2 md:py-4 flex flex-row items-center justify-between gap-2 md:gap-4">
             <div class="flex-shrink-0">
                <img src="logo.png" alt="UPITI Logo" class="h-14 md:h-32 w-auto object-contain">
            </div>
            
            <div class="text-center flex-1 min-w-0">
                <h1 class="text-[13px] sm:text-lg md:text-5xl text-red-600 font-bold leading-tight whitespace-nowrap overflow-hidden">
                    उत्तर प्रदेश औद्योगिक प्रशिक्षण संस्थान कर्मचारी संघ
                </h1>
                <h2 class="text-[8px] sm:text-xs md:text-3xl font-extrabold text-blue-900 leading-tight whitespace-nowrap overflow-hidden" style="font-family: 'Cambria', serif;">
                    UTTAR PRADESH INDUSTRIAL TRAINING INSTITUTE EMPLOYEES UNION.
                </h2>
                <p class="text-[7px] sm:text-[10px] md:text-base text-gray-600 font-semibold uppercase tracking-tight whitespace-nowrap overflow-hidden">
                    (उ0 प्र0 शासन, श्रम अनुभाग-6, संख्या 482/36-6-207/71 लखनऊ दिनांक 1 मार्च, 1974 द्वारा मान्यता प्राप्त)
                </p>
                <p class="text-[8px] sm:text-[10px] md:text-base text-red-600 font-semibold uppercase whitespace-nowrap overflow-hidden">
                    सम्बद्ध: राज्य कर्मचारी संयुक्त परिषद, उत्तर प्रदेश
                </p>
            </div>

            <div class="hidden md:block md:w-32"></div>
        </div>
    </header>

    <nav class="bg-blue-800 text-white shadow-lg sticky top-0 z-50">
        <div class="container mx-auto px-4">
            <ul class="flex flex-wrap items-center justify-center md:justify-start space-x-1 md:space-x-6 py-3 text-sm md:text-base font-medium">
                <li><a href="/index" class="hover:bg-blue-700 px-3 py-2 rounded transition">मुख्य पृष्ठ</a></li>
                <li><a href="/about" class="hover:bg-blue-700 px-3 py-2 rounded transition">हमारे बारे में</a></li>
                <li><a href="/organization" class="hover:bg-blue-700 px-3 py-2 rounded transition">संगठन संरचना</a></li>
                <li><a href="/events" class="hover:bg-blue-700 px-3 py-2 rounded transition">घटनाक्रम</a></li>
                <li><a href="/gallery" class="hover:bg-blue-700 px-3 py-2 rounded transition">गैलरी</a></li>
                <li><a href="/orders" class="hover:bg-blue-700 px-3 py-2 rounded transition">शासनादेश / आदेश</a></li>
                <li><a href="/contact" class="hover:bg-blue-700 px-3 py-2 rounded transition">सम्पर्क सूत्र</a></li>
            </ul>
        </div>
    </nav>

    <section class="w-full relative">
        <div x-data="{ activeSlide: 1 }" 
             x-init="setInterval(() => { activeSlide = activeSlide === 5 ? 1 : activeSlide + 1 }, 3000)" 
             class="relative w-full aspect-video md:aspect-[21/9] overflow-hidden shadow-lg">
             <div x-show="activeSlide === 1" x-transition.opacity.duration.500ms class="absolute inset-0">
                <img src="/new-slide-1.jpeg" alt="Slide 1" class="w-full h-full object-cover">
             </div>
             <div x-show="activeSlide === 2" x-transition.opacity.duration.500ms class="absolute inset-0">
                <img src="/new-slide-2.jpeg" alt="Slide 2" class="w-full h-full object-cover">
             </div>
             <div x-show="activeSlide === 3" x-transition.opacity.duration.500ms class="absolute inset-0">
                <img src="/new-slide-3.jpeg" alt="Slide 3" class="w-full h-full object-cover">
             </div>
             <div x-show="activeSlide === 4" x-transition.opacity.duration.500ms class="absolute inset-0">
                <img src="/new-slide-4.jpeg" alt="Slide 4" class="w-full h-full object-cover">
             </div>
             <div x-show="activeSlide === 5" x-transition.opacity.duration.500ms class="absolute inset-0">
                <img src="/new-slide-5.jpeg" alt="Slide 5" class="w-full h-full object-cover">
             </div>
        </div>
    </section>

    <main class="container mx-auto px-4 py-8 space-y-8">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <section class="bg-white p-6 rounded-lg shadow border border-gray-200 md:col-span-2">
                <h2 class="text-2xl font-bold text-blue-800 mb-4 border-b-2 border-red-500 pb-2 inline-block">परिचय (Introduction)</h2>
                <p class="text-gray-700 leading-relaxed mb-4">
                    उत्तर प्रदेश औद्योगिक प्रशिक्षण संस्थान कर्मचारी संघ में आपका स्वागत है। यह संगठन कर्मचारियों के हितों और अधिकारों की रक्षा के लिए समर्पित है...
                </p>
                <a href="#" class="text-blue-600 font-semibold hover:text-blue-800 underline">Read more...</a>
            </section>
            <section class="bg-white p-6 rounded-lg shadow border border-gray-200 flex items-center justify-center">
                <img src="vivek.png" alt="Profile Photo" class="w-full max-w-sm h-auto rounded-lg shadow-md object-cover">
            </section>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <section class="bg-white p-6 rounded-lg shadow border border-gray-200 border-t-4 border-t-red-600">
                <h3 class="text-xl font-bold text-gray-800 mb-4 flex items-center">
                    <i class="fa-solid fa-bell text-red-600 mr-2"></i> नवीनतम सूचनाएं
                </h3>
                <div class="bg-gray-50 p-4 h-48 overflow-y-auto rounded shadow-inner text-sm text-blue-800">
                    <ul class="space-y-2">
                        <li class="border-b pb-1 hover:text-red-600 cursor-pointer">नवीनतम बैठक और निर्णय।</li>
                        <li class="border-b pb-1 hover:text-red-600 cursor-pointer">कर्मचारी कल्याण नई सूचना।</li>
                    </ul>
                </div>
            </section>
            <section class="bg-white p-6 rounded-lg shadow border border-gray-200 border-t-4 border-t-blue-600">
                <h3 class="text-xl font-bold text-gray-800 mb-4 flex items-center">
                    <i class="fa-solid fa-file-pdf text-blue-600 mr-2"></i> शासनादेश
                </h3>
                <div class="bg-gray-50 p-4 h-48 overflow-y-auto rounded shadow-inner text-sm text-blue-800">
                    <ul class="space-y-2">
                        <li class="border-b pb-1 hover:text-red-600 cursor-pointer">नवीनतम शासनादेश डाउनलोड करें।</li>
                    </ul>
                </div>
            </section>
            <section class="bg-white p-6 rounded-lg shadow border border-gray-200 border-t-4 border-t-green-600">
                <h3 class="text-xl font-bold text-gray-800 mb-4 flex items-center">
                    <i class="fa-solid fa-calendar-days text-green-600 mr-2"></i> आगामी कार्यक्रम
                </h3>
                <div class="bg-gray-50 p-4 h-48 overflow-y-auto rounded shadow-inner text-sm text-blue-800">
                    <ul class="space-y-2">
                        <li class="border-b pb-1 hover:text-red-600 cursor-pointer">आगामी कार्यक्रमों की रूपरेखा।</li>
                    </ul>
                </div>
            </section>
        </div>

        <div class="bg-blue-50 p-6 rounded-lg shadow border border-blue-200">
            <h3 class="text-lg font-bold text-blue-800 mb-2">संपर्क (Contact)</h3>
            <p class="text-gray-700 flex items-center">
                <i class="fa-solid fa-envelope text-blue-600 mr-2"></i> 
                <a href="mailto:upitien@gmail.com" class="hover:underline">upitien@gmail.com</a>
            </p>
        </div>
    </main>

    <footer class="bg-gray-900 text-gray-300 py-8 border-t-4 border-blue-700 mt-auto">
        <div class="container mx-auto px-4 grid grid-cols-1 md:grid-cols-3 gap-8">
            <div>
                <h4 class="text-white text-lg font-bold mb-4">UPITI Employees Association</h4>
                <p class="text-sm">राज्य कर्मचारी संयुक्त परिषद, उत्तर प्रदेश से संबद्ध एक प्रमुख कर्मचारी संगठन।</p>
            </div>
            <div class="flex flex-col items-center md:items-start">
                <h4 class="text-white text-lg font-bold mb-4">Connect With Us</h4>
                <div class="flex space-x-4">
                    <a href="#" class="w-10 h-10 bg-blue-600 text-white flex items-center justify-center rounded-full hover:bg-blue-500 transition shadow">
                        <i class="fa-brands fa-facebook-f"></i>
                    </a>
                    <a href="#" class="w-10 h-10 bg-sky-500 text-white flex items-center justify-center rounded-full hover:bg-sky-400 transition shadow">
                        <i class="fa-brands fa-twitter"></i>
                    </a>
                    <a href="#" class="w-10 h-10 bg-red-600 text-white flex items-center justify-center rounded-full hover:bg-red-500 transition shadow">
                        <i class="fa-brands fa-youtube"></i>
                    </a>
                </div>
            </div>
            <div class="text-center md:text-right">
                <h4 class="text-white text-lg font-bold mb-4">Visitor Statistics</h4>
                <div class="inline-block bg-gray-800 border border-gray-700 px-4 py-2 rounded text-xl font-mono text-green-400 tracking-widest shadow-inner mb-2">
                    211131
                </div>
                <br>
                <div class="inline-block bg-gray-800 border border-gray-700 px-4 py-2 rounded text-xl font-mono text-green-400 tracking-widest shadow-inner">
                    0000000
                </div>
            </div>
        </div>
        <div class="mt-8 pt-4 border-t border-gray-800 text-center text-xs text-gray-500">
            &copy; 2026 UTTAR Pradesh Industrial Training Institute Employees Association. All rights reserved.
        </div>
    </footer>

</body>
</html>
