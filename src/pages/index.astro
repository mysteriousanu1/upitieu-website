<script is:inline src="https://cdn.tailwindcss.com"></script>
<!DOCTYPE html>
<html lang="hi">
<head>
    <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>UPITI Employees Association</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-gray-50 text-gray-800 font-sans flex flex-col min-h-screen">

    <header class="bg-white shadow-md border-b-4 border-blue-700">
        <div class="container mx-auto px-4 py-4 flex flex-col md:flex-row items-center justify-center md:justify-between">
             <div class="flex items-center mb-4 md:mb-0">
                <img src="logo.png" alt="UPITI Logo" class="h-32 w-auto object-contain">
            </div>
            <div class="text-center flex-1 px-4">
                <h1 class="text-5xl text-red-600 font-bold mb-2">उत्तर प्रदेश औद्योगिक प्रशिक्षण संस्थान कर्मचारी संघ</h1>
                <h2 class="text-2xl md:text-3xl font-extrabold text-blue-400 mb-1">UTTAR Pradesh Industrial Training Institute Employees Association.</h2>
                <p class="text-sm md:text-base text-gray-600 font-semibold uppercase tracking-wide">(उ0 प्र0 शासन, श्रम अनुभाग-6, संख्या 482/36-6-207/71 लखनऊ दिनांक 1 मार्च, 1974 द्वारा मान्यता प्राप्त)</p>
                <p class="text-sm md:text-base text-gray-600 font-semibold uppercase tracking-wide">सम्बद्ध: राज्य कर्मचारी संयुक्त परिषद, उत्तर प्रदेश</p>
            </div>
        </div>
    </header>

    <nav class="bg-blue-800 text-white shadow-lg sticky top-0 z-50">
        <div class="container mx-auto px-4">
            <ul class="flex flex-wrap items-center justify-center md:justify-start space-x-1 md:space-x-6 py-3 text-sm md:text-base font-medium">
                <li><a href="#" class="hover:bg-blue-700 px-3 py-2 rounded transition">मुख्य पृष्ठ</a></li>
                <li><a href="#" class="hover:bg-blue-700 px-3 py-2 rounded transition">हमारे बारे में</a></li>
                <li><a href="#" class="hover:bg-blue-700 px-3 py-2 rounded transition">संगठन संरचना</a></li>
                <li><a href="#" class="hover:bg-blue-700 px-3 py-2 rounded transition">घटनाक्रम</a></li>
                <li><a href="#" class="hover:bg-blue-700 px-3 py-2 rounded transition">गैलरी</a></li>
                <li><a href="#" class="hover:bg-blue-700 px-3 py-2 rounded transition">शासनादेश / आदेश</a></li>
                <li><a href="#" class="hover:bg-blue-700 px-3 py-2 rounded transition">सम्पर्क सूत्र</a></li>
            </ul>
        </div>
    </nav>

    <section class="w-full relative mb-8">
        <div x-data="{ activeSlide: 1 }" 
             x-init="setInterval(() => { activeSlide = activeSlide === 5 ? 1 : activeSlide + 1 }, 3000)" 
             class="relative w-full h-[300px] md:h-[500px] overflow-hidden shadow-lg">
             <img src="slide-1.jpg" alt="Slide" class="w-full h-full object-cover">
        </div>
    </section>

    <main class="container mx-auto px-4 py-8 grid grid-cols-1 md:grid-cols-3 gap-6">
        
        <section class="md:col-span-3 bg-white p-6 rounded-lg shadow border border-gray-200 flex flex-col md:flex-row gap-8 items-start">
            <div class="flex-1">
                <h2 class="text-2xl font-bold text-blue-800 mb-4 border-b-2 border-red-500 pb-2 inline-block">परिचय (Introduction)</h2>
                <p class="text-gray-700 leading-relaxed mb-4">
                    उत्तर प्रदेश औद्योगिक प्रशिक्षण संस्थान कर्मचारी संघ में आपका स्वागत है। यह संगठन कर्मचारियों के हितों और अधिकारों की रक्षा के लिए समर्पित है...
                </p>
                <a href="#" class="text-blue-600 font-semibold hover:text-blue-800 underline">Read more...</a>
            </div>
            <div class="w-full md:w-64 flex-shrink-0">
                <img src="vivek.png" alt="Vivek" class="w-full h-auto rounded-lg shadow-md object-cover border-2 border-blue-100">
            </div>
        </section>

        <section class="bg-white p-6 rounded-lg shadow border border-gray-200 border-t-4 border-t-red-600">
            <h3 class="text-xl font-bold text-gray-800 mb-4 flex items-center">
                <i class="fa-solid fa-bell text-red-600 mr-2"></i> नवीन सूचानाएं
            </h3>
            <div class="bg-gray-50 p-4 border border-gray-100 h-64 overflow-y-auto rounded shadow-inner">
                <marquee direction="up" scrollamount="2" class="h-full">
                    <ul class="space-y-4 text-sm text-blue-800 font-medium">
                        <li class="border-b pb-2 hover:text-red-600 cursor-pointer">नवीनतम बैठक और निर्णय की जानकारी।</li>
                        <li class="border-b pb-2 hover:text-red-600 cursor-pointer">कर्मचारी कल्याण से जुड़ी नई सूचनाएं।</li>
                    </ul>
                </marquee>
            </div>
        </section>

        <div class="bg-blue-50 p-6 rounded-lg shadow border border-blue-200">
            <h3 class="text-lg font-bold text-blue-800 mb-2">संपर्क (Contact)</h3>
            <p class="text-gray-700 flex items-center">
                <i class="fa-solid fa-envelope text-blue-600 mr-2"></i> 
                <a href="mailto:upitien@gmail.com" class="hover:underline">upitien@gmail.com</a>
            </p>
        </div>

        <div class="bg-gray-100 p-6 rounded-lg shadow border border-gray-200">
            <h3 class="text-lg font-bold text-gray-800 mb-2">त्वरित लिंक</h3>
            <ul class="text-blue-700 text-sm space-y-2">
                <li><a href="#" class="hover:underline">→ शासनादेश डाउनलोड</a></li>
                <li><a href="#" class="hover:underline">→ सदस्यता फॉर्म</a></li>
                <li><a href="#" class="hover:underline">→ DGT वेबसाइट</a></li>
            </ul>
        </div>

    </main>

    <footer class="bg-gray-900 text-gray-300 py-8 border-t-4 border-blue-700 mt-auto">
        <div class="container mx-auto px-4 text-center">
            <p class="text-sm">&copy; 2026 UTTAR Pradesh Industrial Training Institute Employees Association. All rights reserved.</p>
        </div>
    </footer>

</body>
</html>
