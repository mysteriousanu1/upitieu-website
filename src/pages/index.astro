<script is:inline src="https://cdn.tailwindcss.com"></script>
<!DOCTYPE html>
<html lang="hi">
<head>
    <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>UPITI Employees Association</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-gray-100 text-gray-800 font-sans flex flex-col min-h-screen">

    <header class="bg-white shadow-sm border-b-4 border-blue-800">
        <div class="container mx-auto px-4 py-4 flex flex-col md:flex-row items-center justify-center md:justify-between">
             <div class="flex items-center mb-4 md:mb-0">
                <img src="logo.png" alt="UPITI Logo" class="h-24 w-auto object-contain">
            </div>
            <div class="text-center flex-1 px-4">
                <h1 class="text-3xl md:text-4xl text-blue-900 font-bold mb-1">उत्तर प्रदेश औद्योगिक प्रशिक्षण संस्थान कर्मचारी संघ</h1>
                <h2 class="text-xl md:text-2xl font-bold text-red-700 mb-2">UTTAR Pradesh Industrial Training Institute Employees Association</h2>
                <p class="text-xs text-gray-600 font-medium uppercase tracking-wider italic">
                    (उ0 प्र0 शासन, श्रम अनुभाग-6 मान्यता प्राप्त) | सम्बद्ध: राज्य कर्मचारी संयुक्त परिषद, उत्तर प्रदेश
                </p>
            </div>
        </div>
    </header>

    <nav class="bg-blue-800 text-white shadow-lg sticky top-0 z-50">
        <div class="container mx-auto px-4">
            <ul class="flex flex-wrap items-center justify-center md:justify-start space-x-1 md:space-x-6 py-3 text-sm font-semibold">
                <li><a href="#" class="hover:bg-blue-900 px-3 py-2 rounded transition">मुख्य पृष्ठ</a></li>
                <li><a href="#" class="hover:bg-blue-900 px-3 py-2 rounded transition">हमारे बारे में</a></li>
                <li><a href="#" class="hover:bg-blue-900 px-3 py-2 rounded transition">संगठन संरचना</a></li>
                <li><a href="#" class="hover:bg-blue-900 px-3 py-2 rounded transition">शासनादेश / आदेश</a></li>
                <li><a href="#" class="hover:bg-blue-900 px-3 py-2 rounded transition">गैलरी</a></li>
                <li><a href="#" class="hover:bg-blue-900 px-3 py-2 rounded transition">सम्पर्क सूत्र</a></li>
            </ul>
        </div>
    </nav>

    <section class="w-full relative bg-gray-200">
        <div x-data="{ activeSlide: 1 }" 
             x-init="setInterval(() => { activeSlide = activeSlide === 5 ? 1 : activeSlide + 1 }, 3000)" 
             class="relative w-full h-[300px] md:h-[450px] overflow-hidden">
             <img src="slide-1.jpg" alt="Slide" class="w-full h-full object-cover">
        </div>
    </section>

    <main class="container mx-auto px-4 py-8 grid grid-cols-1 md:grid-cols-3 gap-6">
        
        <section class="md:col-span-3 bg-white p-6 rounded-lg shadow-md border-t-4 border-blue-600 flex flex-col md:flex-row gap-8 items-start">
            <div class="flex-1">
                <h2 class="text-2xl font-bold text-blue-900 mb-4 border-b border-gray-200 pb-2">परिचय (Introduction)</h2>
                <p class="text-gray-700 leading-relaxed mb-4 text-justify">
                    उत्तर प्रदेश औद्योगिक प्रशिक्षण संस्थान कर्मचारी संघ में आपका स्वागत है। यह संगठन कर्मचारियों के हितों और अधिकारों की रक्षा के लिए समर्पित है। हम राज्य की औद्योगिक प्रशिक्षण इकाइयों के कर्मचारियों की आवाज को सरकार तक पहुँचाने और उनके कल्याण के लिए निरंतर प्रयासरत हैं।
                </p>
                <a href="#" class="text-blue-700 font-bold hover:text-blue-900 underline">Read more...</a>
            </div>
            <div class="w-full md:w-56 flex-shrink-0">
                <img src="VIVEK.jpg" alt="VIVEK" class="w-full h-auto rounded border-4 border-white shadow-lg object-cover">
                <p class="text-center text-sm font-bold mt-2 text-gray-600">State President</p>
            </div>
        </section>

        <section class="bg-white p-6 rounded-lg shadow-md border-t-4 border-red-600">
            <h3 class="text-xl font-bold text-gray-800 mb-4 flex items-center">
                <i class="fa-solid fa-bullhorn text-red-600 mr-2"></i> नवीन सूचानाएं
            </h3>
            <div class="bg-gray-50 p-4 rounded h-64 overflow-y-auto">
                <ul class="space-y-4 text-sm text-blue-900 font-medium">
                    <li class="border-b border-gray-200 pb-2 hover:text-red-700 cursor-pointer">→ नवीनतम बैठक और निर्णय की जानकारी।</li>
                    <li class="border-b border-gray-200 pb-2 hover:text-red-700 cursor-pointer">→ कर्मचारी कल्याण से जुड़ी नई सूचनाएं।</li>
                </ul>
            </div>
        </section>

        <div class="bg-white p-6 rounded-lg shadow-md border-t-4 border-blue-600">
            <h3 class="text-xl font-bold text-gray-800 mb-4">संपर्क (Contact)</h3>
            <div class="text-gray-700 text-sm space-y-3">
                <p><i class="fa-solid fa-envelope text-blue-600 mr-2"></i> <a href="mailto:upitien@gmail.com" class="hover:text-blue-800">upitien@gmail.com</a></p>
                <p><i class="fa-solid fa-location-dot text-blue-600 mr-2"></i> Lucknow, Uttar Pradesh</p>
            </div>
        </div>

        <div class="bg-white p-6 rounded-lg shadow-md border-t-4 border-green-600">
            <h3 class="text-xl font-bold text-gray-800 mb-4">त्वरित लिंक</h3>
            <ul class="text-blue-800 text-sm space-y-2 font-semibold">
                <li><a href="#" class="hover:underline">→ शासनादेश डाउनलोड</a></li>
                <li><a href="#" class="hover:underline">→ सदस्यता फॉर्म</a></li>
                <li><a href="#" class="hover:underline">→ कौशल विकास मंत्रालय</a></li>
            </ul>
        </div>
    </main>

    <footer class="bg-gray-800 text-gray-300 py-8 border-t-4 border-blue-800 mt-auto">
        <div class="container mx-auto px-4 text-center">
            <p class="text-sm">&copy; 2026 UTTAR Pradesh Industrial Training Institute Employees Association. All rights reserved.</p>
        </div>
    </footer>

</body>
</html>
