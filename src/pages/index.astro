<!DOCTYPE html>
<html lang="hi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>UPITI Employees Association</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-gray-50 text-gray-800">

    <header class="w-full bg-white border-b-4 border-blue-700 shadow-md">
        <div class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
            <div class="w-20 md:w-32 flex-shrink-0">
                <img src="logo.png" alt="Logo" class="w-full h-auto object-contain">
            </div>
            
            <div class="flex-1 text-center px-4">
                <h1 class="text-xl md:text-3xl font-bold text-red-600">उत्तर प्रदेश औद्योगिक प्रशिक्षण संस्थान कर्मचारी संघ</h1>
                <h2 class="text-xs md:text-lg font-bold text-blue-500">UTTAR Pradesh Industrial Training Institute Employees Association.</h2>
            </div>

            <div class="w-20 md:w-32 flex-shrink-0">
                <img src="logo2.png" alt="Logo" class="w-full h-auto object-contain">
            </div>
        </div>
    </header>

    <nav class="w-full bg-blue-800 text-white">
        <div class="max-w-6xl mx-auto px-4 py-3 text-center">
            <span class="font-bold">Navigation Menu</span>
        </div>
    </nav>

    <div class="max-w-6xl mx-auto px-4 mt-6">
        <div x-data="{ activeSlide: 1 }" 
             x-init="setInterval(() => { activeSlide = activeSlide === 5 ? 1 : activeSlide + 1 }, 5000)" 
             class="relative w-full overflow-hidden shadow-lg rounded-xl border border-gray-200">
            
            <div class="relative w-full aspect-[21/7]">
                <div x-show="activeSlide === 1" class="absolute inset-0"><img src="slide-1.jpg" class="w-full h-full object-cover"></div>
                <div x-show="activeSlide === 2" class="absolute inset-0"><img src="slide-2.jpg" class="w-full h-full object-cover"></div>
                <div x-show="activeSlide === 3" class="absolute inset-0"><img src="slide-3.jpg" class="w-full h-full object-cover"></div>
                <div x-show="activeSlide === 4" class="absolute inset-0"><img src="slide-4.jpg" class="w-full h-full object-cover"></div>
                <div x-show="activeSlide === 5" class="absolute inset-0"><img src="slide-5.jpg" class="w-full h-full object-cover"></div>
            </div>
        </div>
    </div>

    <main class="max-w-6xl mx-auto px-4 py-8">
        <section class="bg-white p-6 rounded-lg shadow border border-gray-200">
            <h2 class="text-2xl font-bold text-blue-800 mb-4 border-b-2 border-red-500 inline-block">परिचय (Introduction)</h2>
            <p>Welcome to the portal...</p>
        </section>
    </main>

</body>
</html>
