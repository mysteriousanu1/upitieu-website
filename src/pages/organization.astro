<script is:inline src="https://cdn.tailwindcss.com"></script>
<!DOCTYPE html>
<html lang="hi">
<head>
    <script is:inline defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>संगठन संरचना - UPITI Employees Association</title>
    <script is:inline src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-gray-50 text-gray-800 font-sans flex flex-col min-h-screen">

    <header class="bg-white shadow-md border-b-4 border-blue-700">
        <div class="container mx-auto px-4 py-4 flex flex-col md:flex-row items-center justify-center md:justify-between">
             <div class="flex items-center mb-4 md:mb-0">
                <img src="/logo.png" alt="UPITI Logo" class="h-32 w-auto object-contain">
            </div>
            <div class="text-center flex-1 px-4">
                <h1 class="text-5xl text-red-600 font-bold mb-2">उत्तर प्रदेश औद्योगिक प्रशिक्षण संस्थान कर्मचारी संघ</h1>
                <h2 class="text-2xl md:text-3xl font-extrabold text-blue-900 mb-1" style="font-family: 'Cambria', serif;">UTTAR PRADESH INDUSTRIAL TRAINING INSTITUTE EMPLOYEES UNION.</h2>
                <p class="text-sm md:text-base text-gray-600 font-semibold uppercase tracking-wide">(उ0 प्र0 शासन, श्रम अनुभाग-6, संख्या 482/36-6-207/71 लखनऊ दिनांक 1 मार्च, 1974 द्वारा मान्यता प्राप्त)</p>
                <p class="text-sm md:text-base text-red-600 font-semibold uppercase tracking-wide">सम्बद्ध: राज्य कर्मचारी संयुक्त परिषद, उत्तर प्रदेश</p>
            </div>
        </div>
    </header>

    <nav class="bg-blue-800 text-white shadow-lg sticky top-0 z-50">
        <div class="container mx-auto px-4">
            <ul class="flex flex-wrap items-center justify-center md:justify-start space-x-1 md:space-x-6 py-3 text-sm md:text-base font-medium">
                <li><a href="/index" class="hover:bg-blue-700 px-3 py-2 rounded transition">मुख्य पृष्ठ</a></li>
                <li><a href="/about" class="hover:bg-blue-700 px-3 py-2 rounded transition">हमारे बारे में</a></li>
                <li><a href="/organization" class="bg-blue-900 px-3 py-2 rounded transition">संगठन संरचना</a></li>
                <li><a href="/events" class="hover:bg-blue-700 px-3 py-2 rounded transition">घटनाक्रम</a></li>
                <li><a href="/gallery" class="hover:bg-blue-700 px-3 py-2 rounded transition">गैलरी</a></li>
                <li><a href="/orders" class="hover:bg-blue-700 px-3 py-2 rounded transition">शासनादेश / आदेश</a></li>
                <li><a href="/contact" class="hover:bg-blue-700 px-3 py-2 rounded transition">सम्पर्क सूत्र</a></li>
            </ul>
        </div>
    </nav>

    <main class="container mx-auto px-4 py-12 flex-grow" x-data="{ tab: 'prantiya' }">
        
        <div class="text-center mb-10">
            <h2 class="text-3xl md:text-4xl font-bold text-blue-800 border-b-4 border-red-500 inline-block pb-2">संगठन संरचना</h2>
            <p class="text-gray-600 mt-4 text-lg">उत्तर प्रदेश औद्योगिक प्रशिक्षण संस्थान कर्मचारी संघ की कार्यकारिणी समितियां</p>
        </div>

        <div class="flex flex-col sm:flex-row justify-center items-center space-y-3 sm:space-y-0 sm:space-x-4 mb-12 border-b-2 border-gray-200 pb-4 max-w-4xl mx-auto">
            <button @click="tab = 'prantiya'" 
                    :class="tab === 'prantiya' ? 'bg-red-600 text-white shadow-lg scale-105' : 'bg-gray-100 text-gray-700 hover:bg-gray-200 border border-gray-300'" 
                    class="w-full sm:w-auto px-6 py-3 font-bold rounded-lg transition-all duration-300 text-lg flex items-center justify-center">
                <i class="fa-solid fa-sitemap mr-2"></i> प्रान्तीय पदाधिकारी
            </button>
            <button @click="tab = 'mandaliya'" 
                    :class="tab === 'mandaliya' ? 'bg-blue-700 text-white shadow-lg scale-105' : 'bg-gray-100 text-gray-700 hover:bg-gray-200 border border-gray-300'" 
                    class="w-full sm:w-auto px-6 py-3 font-bold rounded-lg transition-all duration-300 text-lg flex items-center justify-center">
                <i class="fa-solid fa-users mr-2"></i> मण्डलीय पदाधिकारी
            </button>
            <button @click="tab = 'janpadiya'" 
                    :class="tab === 'janpadiya' ? 'bg-green-700 text-white shadow-lg scale-105' : 'bg-gray-100 text-gray-700 hover:bg-gray-200 border border-gray-300'" 
                    class="w-full sm:w-auto px-6 py-3 font-bold rounded-lg transition-all duration-300 text-lg flex items-center justify-center">
                <i class="fa-solid fa-user-group mr-2"></i> जनपदीय पदाधिकारी
            </button>
        </div>

        <div x-show="tab === 'prantiya'" x-transition.opacity.duration.500ms>
            <div class="flex flex-col items-center space-y-10">
                <div class="w-full max-w-4xl grid grid-cols-1 md:grid-cols-2 gap-8 border-b-2 border-gray-200 pb-10">
                    <div class="bg-amber-50 p-6 rounded-xl shadow-md border-t-4 border-amber-500 text-center flex flex-col items-center justify-center">
                        <i class="fa-solid fa-crown text-3xl text-amber-500 mb-3"></i>
                        <p class="text-amber-700 font-bold mb-1 uppercase tracking-wider text-sm">संघ संरक्षक</p>
                        <h3 class="text-2xl font-bold text-gray-800">मो० ई० एच० जैदी</h3>
                    </div>
                    <div class="bg-amber-50 p-6 rounded-xl shadow-md border-t-4 border-amber-500 text-center flex flex-col items-center justify-center">
                        <i class="fa-solid fa-crown text-3xl text-amber-500 mb-3"></i>
                        <p class="text-amber-700 font-bold mb-1 uppercase tracking-wider text-sm">संघ संरक्षक</p>
                        <h3 class="text-2xl font-bold text-gray-800">श्री अनिल कु० पाठक</h3>
                    </div>
                </div>

                <div class="w-full max-w-sm">
                    <div class="bg-white p-8 rounded-xl shadow-2xl border-t-4 border-red-600 text-center transform transition hover:-translate-y-2">
                        <div class="w-36 h-36 rounded-full mx-auto bg-gray-100 flex items-center justify-center border-4 border-gray-200 shadow-sm mb-5 overflow-hidden">
                            <img src="/vivek.png" alt="अध्यक्ष" class="w-full h-full object-cover" onerror="this.style.display='none'; this.nextElementSibling.style.display='block';">
                            <i class="fa-solid fa-user-tie text-6xl text-gray-400 hidden"></i>
                        </div>
                        <h3 class="text-3xl font-bold text-gray-800 mb-1">श्री [नाम]</h3>
                        <p class="text-red-600 font-black text-xl mb-2 tracking-wide">1. अध्यक्ष</p>
                    </div>
                </div>
            </div>
        </div>

        <div x-show="tab === 'mandaliya'" style="display: none;" x-transition.opacity.duration.500ms>
            <div x-data="{ 
                activeMandal: 'आगरा',
                mandalList: [
                    { name: 'आगरा', adhyaksh: 'श्री [नाम]', mantri: 'श्री [नाम]' },
                    { name: 'अलीगढ़', adhyaksh: 'श्री [नाम]', mantri: 'श्री [नाम]' },
                    { name: 'अयोध्या', adhyaksh: 'श्री [नाम]', mantri: 'श्री [नाम]' },
                    { name: 'आज़मगढ़', adhyaksh: 'श्री [नाम]', mantri: 'श्री [नाम]' },
                    { name: 'बरेली', adhyaksh: 'श्री [नाम]', mantri: 'श्री [नाम]' },
                    { name: 'बस्ती', adhyaksh: 'श्री [नाम]', mantri: 'श्री [नाम]' },
                    { name: 'चित्रकूट', adhyaksh: 'श्री [नाम]', mantri: 'श्री [नाम]' },
                    { name: 'देवीपाटन', adhyaksh: 'श्री [नाम]', mantri: 'श्री [नाम]' },
                    { name: 'गोरखपुर', adhyaksh: 'श्री [नाम]', mantri: 'श्री [नाम]' },
                    { name: 'झाँसी', adhyaksh: 'श्री [नाम]', mantri: 'श्री [नाम]' },
                    { name: 'कानपुर', adhyaksh: 'श्री [नाम]', mantri: 'श्री [नाम]' },
                    { name: 'लखनऊ', adhyaksh: 'श्री [नाम]', mantri: 'श्री [नाम]' },
                    { name: 'मेरठ', adhyaksh: 'श्री [नाम]', mantri: 'श्री [नाम]' },
                    { name: 'मिर्ज़ापुर', adhyaksh: 'श्री [नाम]', mantri: 'श्री [नाम]' },
                    { name: 'मुरादाबाद', adhyaksh: 'श्री [नाम]', mantri: 'श्री [नाम]' },
                    { name: 'प्रयागराज', adhyaksh: 'श्री [नाम]', mantri: 'श्री [नाम]' },
                    { name: 'सहारनपुर', adhyaksh: 'श्री [नाम]', mantri: 'श्री [नाम]' },
                    { name: 'वाराणसी', adhyaksh: 'श्री [नाम]', mantri: 'श्री [नाम]' }
                ]
            }">
                <div class="flex flex-col md:flex-row gap-6 max-w-5xl mx-auto">
                    <div class="w-full md:w-1/3 bg-white border border-gray-200 rounded-xl p-4 shadow-sm">
                        <h3 class="font-bold text-blue-800 mb-4 px-2 border-b pb-2 text-lg">मण्डल सूची</h3>
                        <div class="h-[500px] overflow-y-auto space-y-2 pr-2 custom-scrollbar">
                            <template x-for="m in mandalList" :key="m.name">
                                <button @click="activeMandal = m.name" 
                                        :class="activeMandal === m.name ? 'bg-blue-700 text-white shadow-md' : 'bg-gray-50 text-gray-700 hover:bg-blue-50'"
                                        class="w-full text-left px-4 py-3 rounded-lg font-semibold transition border border-gray-100 text-sm md:text-base">
                                    <i class="fa-solid fa-map-pin mr-2 opacity-70"></i> <span x-text="m.name + ' मण्डल'"></span>
                                </button>
                            </template>
                        </div>
                    </div>

                    <div class="w-full md:w-2/3">
                        <template x-for="m in mandalList" :key="'content-'+m.name">
                            <div x-show="activeMandal === m.name" 
                                 class="bg-white border-t-4 border-blue-700 p-8 rounded-xl shadow-lg transition-all animate-in fade-in duration-300">
                                <div class="text-center mb-8">
                                    <h2 class="text-3xl font-extrabold text-gray-800" x-text="m.name + ' मण्डल'"></h2>
                                    <div class="h-1 w-20 bg-red-500 mx-auto mt-2"></div>
                                </div>
                                <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                                    <div class="bg-gray-50 p-6 rounded-lg border border-gray-200 text-center">
                                        <div class="w-24 h-24 bg-white rounded-full mx-auto mb-4 flex items-center justify-center border-2 border-gray-200 shadow-inner">
                                            <i class="fa-solid fa-user-tie text-4xl text-gray-400"></i>
                                        </div>
                                        <h4 class="font-bold text-xl text-gray-800" x-text="m.adhyaksh"></h4>
                                        <p class="text-red-600 font-semibold uppercase text-sm mt-1">मण्डलीय अध्यक्ष</p>
                                    </div>
                                    <div class="bg-gray-50 p-6 rounded-lg border border-gray-200 text-center">
                                        <div class="w-24 h-24 bg-white rounded-full mx-auto mb-4 flex items-center justify-center border-2 border-gray-200 shadow-inner">
                                            <i class="fa-solid fa-user-pen text-4xl text-gray-400"></i>
                                        </div>
                                        <h4 class="font-bold text-xl text-gray-800" x-text="m.mantri"></h4>
                                        <p class="text-blue-700 font-semibold uppercase text-sm mt-1">मण्डलीय मंत्री</p>
                                    </div>
                                </div>
                            </div>
                        </template>
                    </div>
                </div>
            </div>
        </div>

        <div x-show="tab === 'janpadiya'" style="display: none;" x-transition.opacity.duration.500ms>
             <div class="bg-white border border-gray-200 p-8 rounded-xl shadow-md text-center max-w-4xl mx-auto">
                <i class="fa-solid fa-building-user text-5xl text-green-500 mb-4"></i>
                <h3 class="text-2xl font-bold text-gray-800 mb-4">जनपदीय पदाधिकारी सूची</h3>
                <p class="text-gray-600 mb-6">यहाँ प्रदेश के सभी जनपदों की जानकारी उपलब्ध है।</p>
            </div>
        </div>
    </main>

    <footer class="bg-gray-900 text-gray-300 py-8 border-t-4 border-blue-700 mt-auto">
        <div class="container mx-auto px-4 grid grid-cols-1 md:grid-cols-3 gap-8">
            <div>
                <h4 class="text-white text-lg font-bold mb-4">UPITI Employees Association</h4>
                <p class="text-sm">राज्य कर्मचारी संयुक्त परिषद, उत्तर प्रदेश से संबद्ध एक प्रमुख कर्मचारी संगठन।</p>
            </div>
            <div class="flex flex-col items-center md:items-start">
                <h4 class="text-white text-lg font-bold mb-4">Connect With Us</h4>
                <div class="flex space-x-4">
                    <a href="#" class="w-10 h-10 bg-blue-600 text-white flex items-center justify-center rounded-full hover:bg-blue-500 transition shadow">
                        <i class="fa-brands fa-facebook-f"></i>
                    </a>
                    <a href="#" class="w-10 h-10 bg-sky-500 text-white flex items-center justify-center rounded-full hover:bg-sky-400 transition shadow">
                        <i class="fa-brands fa-twitter"></i>
                    </a>
                    <a href="#" class="w-10 h-10 bg-red-600 text-white flex items-center justify-center rounded-full hover:bg-red-500 transition shadow">
                        <i class="fa-brands fa-youtube"></i>
                    </a>
                </div>
            </div>
            <div class="text-center md:text-right">
                <h4 class="text-white text-lg font-bold mb-4">Visitor Statistics</h4>
                <div class="inline-block bg-gray-800 border border-gray-700 px-4 py-2 rounded text-xl font-mono text-green-400 tracking-widest shadow-inner mb-2">
                    211131
                </div>
                <br>
                <div class="inline-block bg-gray-800 border border-gray-700 px-4 py-2 rounded text-xl font-mono text-green-400 tracking-widest shadow-inner">
                    0000000
                </div>
            </div>
        </div>
        <div class="mt-8 pt-4 border-t border-gray-800 text-center text-xs text-gray-500">
            &copy; 2026 UTTAR Pradesh Industrial Training Institute Employees Association. All rights reserved.
        </div>
    </footer>

    <style>
        .custom-scrollbar::-webkit-scrollbar { width: 6px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: #f1f1f1; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #cbd5e0; border-radius: 10px; }
    </style>

</body>
</html>
